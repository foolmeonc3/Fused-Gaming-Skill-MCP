{
  "name": "@h4shed/skill-syncpulse",
  "version": "0.2.2",
  "description": "SyncPulse - intelligent project state caching, multi-agent coordination, and secure email automation with 9 production-ready templated workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "benchmark": "npm run build && node --expose-gc dist/benchmarks/performance.benchmark.js",
    "benchmark:release": "npm run build && node --expose-gc --max-old-space-size=4096 dist/benchmarks/release-performance.benchmark.js",
    "benchmark:runner": "bash scripts/run-release-benchmarks.sh",
    "test": "echo \"tests pending\""
  },
  "dependencies": {
    "@h4shed/mcp-core": "^1.0.4",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
