{
  "name": "@h4shed/design-tokens",
  "version": "1.0.0",
  "description": "SyncPulse Design System - Complete token system with colors, typography, spacing, shadows, animations, and component tokens",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./colors": {
      "types": "./dist/tokens/colors.d.ts",
      "import": "./dist/tokens/colors.js"
    },
    "./typography": {
      "types": "./dist/tokens/typography.d.ts",
      "import": "./dist/tokens/typography.js"
    },
    "./spacing": {
      "types": "./dist/tokens/spacing.d.ts",
      "import": "./dist/tokens/spacing.js"
    },
    "./shadows": {
      "types": "./dist/tokens/shadows.d.ts",
      "import": "./dist/tokens/shadows.js"
    },
    "./motion": {
      "types": "./dist/tokens/motion.d.ts",
      "import": "./dist/tokens/motion.js"
    },
    "./components": {
      "types": "./dist/tokens/components.d.ts",
      "import": "./dist/tokens/components.js"
    },
    "./agents": {
      "types": "./dist/tokens/agents.d.ts",
      "import": "./dist/tokens/agents.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "echo \"No tests yet\"",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "syncpulse",
    "ui-tokens",
    "colors",
    "typography",
    "spacing",
    "animations",
    "shadows",
    "components"
  ],
  "author": "Fused Gaming <info@fused-gaming.io>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fused-gaming/fused-gaming-skill-mcp.git",
    "directory": "packages/design-tokens"
  },
  "homepage": "https://github.com/fused-gaming/fused-gaming-skill-mcp/tree/main/packages/design-tokens",
  "bugs": {
    "url": "https://github.com/fused-gaming/fused-gaming-skill-mcp/issues",
    "email": "support@fused-gaming.io"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
