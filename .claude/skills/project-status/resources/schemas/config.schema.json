{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Status API Configuration",
  "description": "Configuration schema for Project Status API Framework",
  "type": "object",
  "required": ["project", "gates"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Project description",
      "maxLength": 500
    },
    "rfpNumber": {
      "type": "string",
      "description": "RFP identifier (e.g., '25-26-09')",
      "pattern": "^[0-9]{2}-[0-9]{2}-[0-9]{2}$"
    },
    "deadline": {
      "type": "string",
      "description": "RFP submission deadline (ISO 8601)",
      "format": "date-time"
    },
    "gates": {
      "type": "array",
      "description": "Quality gates to track",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "owner"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Gate ID (0-5)",
            "minimum": 0,
            "maximum": 5
          },
          "name": {
            "type": "string",
            "description": "Gate name",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "description": "Responsible agent or team",
            "minLength": 1
          },
          "criteria": {
            "type": "array",
            "description": "Gate completion criteria",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "description": "Agent swarm configuration",
      "items": {
        "type": "object",
        "required": ["id", "role"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Agent unique identifier"
          },
          "role": {
            "type": "string",
            "description": "Agent role/responsibility"
          },
          "priority": {
            "type": "integer",
            "description": "Agent priority (1=high, 3=low)",
            "minimum": 1,
            "maximum": 3
          }
        }
      }
    },
    "metricsInterval": {
      "type": "integer",
      "description": "Metrics update interval in milliseconds",
      "default": 5000,
      "minimum": 1000,
      "maximum": 60000
    },
    "cacheDuration": {
      "type": "integer",
      "description": "Status cache duration in milliseconds",
      "default": 30000,
      "minimum": 0
    },
    "enableMetrics": {
      "type": "boolean",
      "description": "Enable metrics collection",
      "default": true
    },
    "storageType": {
      "type": "string",
      "description": "Metrics storage backend",
      "enum": ["memory", "redis", "database"],
      "default": "memory"
    },
    "webhooks": {
      "type": "array",
      "description": "Webhook configurations for status updates",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook URL",
            "format": "uri"
          },
          "events": {
            "type": "array",
            "description": "Events to trigger webhook",
            "items": {
              "type": "string",
              "enum": ["gate-passed", "gate-failed", "deadline-warning", "agent-down", "task-completed"]
            }
          }
        }
      }
    }
  }
}
