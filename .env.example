# SyncPulse Email Configuration
# Copy this file to .env.local and fill in your SMTP credentials
# IMPORTANT: Never commit actual credentials to version control!

# SMTP Server Configuration
MAIL_HOST=smtp.vln.gg
MAIL_PORT=587
MAIL_SECURE=false

# Email Credentials (use app-specific passwords, not primary account password)
MAIL_USER=test@mail.vln.gg
MAIL_PASS=your-app-specific-password-here

# From Address
MAIL_FROM=noreply@vln.gg

# Optional: Tracking Endpoint Base URL (for analytics)
# MAIL_TRACKING_URL=https://mail.vln.gg/track

# Optional: Email Rate Limiting (emails per second)
# MAIL_RATE_LIMIT=10

# Optional: Email Retry Configuration
# MAIL_RETRY_ATTEMPTS=3
# MAIL_RETRY_DELAY=1000
